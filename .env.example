# Deployment identity: development, staging, or production.
DEPLOYMENT_ENV=development

# Public application URL. Hosted staging must use the deployed HTTPS URL, not localhost.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional post-deployment smoke-test target.
SMOKE_TEST_BASE_URL=
# Set true only when intentionally testing an incomplete deployment that may return 503 from /api/readiness.
SMOKE_ALLOW_UNREADY=false

# PostgreSQL database
DATABASE_URL=postgresql://username:password@localhost:5432/recharza?schema=public

# Persistent-order security. Use separate random values of at least 32 characters.
ORDER_ACCESS_SECRET=
RATE_LIMIT_SALT=

# Emergency operator fallback and scheduled-maintenance gate.
# Normal operator access uses verified STAFF or ADMIN account sessions.
ADMIN_ACCESS_TOKEN=
CRON_SECRET=

# Verified email account roles. Use comma-separated, reviewed addresses.
AUTH_STAFF_EMAILS=
AUTH_ADMIN_EMAILS=
# In non-production, development mode may return the one-time link in the UI.
# Hosted staging and production require Resend configuration and never return raw magic links.
AUTH_EMAIL_DELIVERY_MODE=development

# Email delivery
RESEND_API_KEY=
RESEND_FROM_EMAIL=Recharza <accounts@example.com>

# FazerCards B2B supplier integration. Keep every value server-side.
FAZERCARDS_API_KEY=
FAZERCARDS_API_BASE_URL=https://api.fzr.cards/api/v2
# Comma-separated category IDs reviewed for region, fields, and fulfilment compatibility.
# Synced offers remain unpublished when this allowlist is empty.
FAZERCARDS_PUBLISHED_CATEGORY_IDS=
# Optional comma-separated HTTPS hosts approved for supplier or administrator product media.
# Example: cdn.supplier.example,media.recharza.example
FAZERCARDS_MEDIA_HOSTS=
# Configure only after confirming the exact paths from your FazerCards account/API documentation.
FAZERCARDS_PLAYER_VALIDATION_PATH=
FAZERCARDS_ORDER_CREATE_PATH=
# Must contain {order_id} or :orderId when configured.
FAZERCARDS_ORDER_STATUS_PATH=
# Supplier writes remain dry-run unless this is explicitly true AND the required paths are configured.
FAZERCARDS_ORDER_WRITES_ENABLED=false

# Optional live foreign-exchange source. The default uses Frankfurter v2 with INR as base.
# Keep this server-side. When unavailable, checkout safely falls back to INR display only.
FX_RATE_SOURCE_URL=https://api.frankfurter.dev/v2/rates

# Razorpay Standard Checkout is intentionally restricted to Test Mode in this build.
# RAZORPAY_KEY_ID must start with rzp_test_. Non-test keys are rejected.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_API_BASE_URL=https://api.razorpay.com/v1

# Never commit real credentials. Keep them in your deployment provider's encrypted secret store.
