# Public application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostgreSQL database
DATABASE_URL=postgresql://username:password@localhost:5432/recharza?schema=public

# Persistent-order security. Use separate random values of at least 32 characters.
ORDER_ACCESS_SECRET=
RATE_LIMIT_SALT=

# Temporary internal operator and scheduled-maintenance gates.
# Replace the operator token with staff authentication before production use.
ADMIN_ACCESS_TOKEN=
CRON_SECRET=

# FazerCards B2B supplier integration. Keep the key server-side.
FAZERCARDS_API_KEY=
FAZERCARDS_API_BASE_URL=https://api.fzr.cards/api/v2
# Comma-separated category IDs reviewed for region, fields, and fulfilment compatibility.
# Synced offers remain unpublished when this allowlist is empty.
FAZERCARDS_PUBLISHED_CATEGORY_IDS=

# Authentication groundwork
AUTH_SECRET=

# Razorpay Standard Checkout is intentionally restricted to Test Mode in this build.
# RAZORPAY_KEY_ID must start with rzp_test_. Non-test keys are rejected.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_API_BASE_URL=https://api.razorpay.com/v1

# Email
RESEND_API_KEY=

# Never commit real credentials. Keep them in your deployment provider's secret store.
