# Public application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostgreSQL database
DATABASE_URL=postgresql://username:password@localhost:5432/recharza?schema=public

# Persistent-order security. Use separate random values of at least 32 characters.
ORDER_ACCESS_SECRET=
RATE_LIMIT_SALT=

# Authentication groundwork
AUTH_SECRET=

# Payments remain disabled until provider webhooks are verified.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Email
RESEND_API_KEY=

# Never commit real credentials. Keep them in your deployment provider's secret store.
