generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrderStatus {
  CREATED
  AWAITING_PAYMENT
  PAYMENT_PENDING
  PAID
  FULFILLING
  COMPLETED
  FAILED
  CANCELLED
}

enum WebhookStatus {
  RECEIVED
  PROCESSED
  IGNORED
  FAILED
}

model Customer {
  id              String   @id @default(cuid())
  email           String   @unique
  authSubject     String?  @unique
  emailVerifiedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  orders          Order[]
}

model Order {
  id               String      @id @default(cuid())
  publicId         String      @unique
  idempotencyKey   String      @unique
  accessTokenHash  String
  status           OrderStatus @default(CREATED)
  gameSlug         String
  packageId        String
  packageName      String
  amountInPaise    Int
  currency         String      @default("INR")
  playerId         String
  zoneId           String
  verificationMode String
  paymentProvider  String?
  paymentSessionId String?     @unique
  customerId       String
  customer         Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  events           OrderEvent[]
  webhooks         PaymentWebhook[]
  auditLogs        AdminAuditLog[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([customerId, createdAt])
  @@index([playerId, zoneId, createdAt])
  @@index([status, createdAt])
}

model OrderEvent {
  id        String   @id @default(cuid())
  type      String
  message   String
  metadata  Json?
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
}

model PaymentWebhook {
  id           String        @id @default(cuid())
  provider     String
  eventId      String?
  eventType    String
  payloadHash  String        @unique
  payload      Json
  status       WebhookStatus @default(RECEIVED)
  errorMessage String?
  orderId      String?
  order        Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  receivedAt   DateTime      @default(now())
  processedAt  DateTime?

  @@unique([provider, eventId], name: "provider_event_id")
  @@index([status, receivedAt])
  @@index([orderId, receivedAt])
}

model AdminAuditLog {
  id               String   @id @default(cuid())
  action           String
  actorFingerprint String
  metadata         Json?
  orderId          String?
  order             Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())

  @@index([orderId, createdAt])
  @@index([createdAt])
}

model RateLimitBucket {
  id          String   @id @default(cuid())
  fingerprint String
  route       String
  windowStart DateTime
  count       Int      @default(0)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([fingerprint, route, windowStart], name: "rate_limit_bucket")
  @@index([expiresAt])
}
