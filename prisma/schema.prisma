generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrderStatus {
  CREATED
  AWAITING_PAYMENT
  PAYMENT_PENDING
  PAID
  FULFILLING
  COMPLETED
  FAILED
  CANCELLED
}

enum WebhookStatus {
  RECEIVED
  PROCESSED
  IGNORED
  FAILED
}

enum SupplierSyncStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum AccountRole {
  CUSTOMER
  STAFF
  ADMIN
}

enum AccountAccessStatus {
  ACTIVE
  ORDER_RESTRICTED
  SIGN_IN_RESTRICTED
  SUSPENDED
}

enum AuthTokenPurpose {
  SIGN_IN
}

enum FulfilmentStatus {
  PLANNED
  SUBMITTING
  SUBMITTED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum FulfilmentMode {
  DRY_RUN
  SUPPLIER_WRITE
}

model Customer {
  id                         String              @id @default(cuid())
  email                      String              @unique
  displayName                String?
  username                   String?             @unique
  role                       AccountRole         @default(CUSTOMER)
  accessStatus               AccountAccessStatus @default(ACTIVE)
  restrictionReason          String?
  restrictionUpdatedAt       DateTime?
  staffPermissions           String[]            @default([])
  staffPermissionsConfigured Boolean             @default(false)
  authSubject                String?             @unique
  emailVerifiedAt            DateTime?
  lastLoginAt                DateTime?
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt
  orders                     Order[]
  sessions                   AuthSession[]
  magicLinks                 AuthMagicLink[]
  staffAuditLogs             AdminAuditLog[]      @relation("StaffAuditActor")

  @@index([role, accessStatus, createdAt])
}

model AuthSession {
  id            String   @id @default(cuid())
  tokenHash     String   @unique
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  expiresAt     DateTime
  lastUsedAt    DateTime @default(now())
  revokedAt     DateTime?
  userAgentHash String?
  createdAt     DateTime @default(now())

  @@index([customerId, expiresAt])
  @@index([expiresAt, revokedAt])
}

model AuthMagicLink {
  id                   String           @id @default(cuid())
  tokenHash            String           @unique
  purpose              AuthTokenPurpose @default(SIGN_IN)
  customerId           String
  customer             Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  requestedFingerprint String
  expiresAt            DateTime
  usedAt               DateTime?
  createdAt            DateTime         @default(now())

  @@index([customerId, createdAt])
  @@index([expiresAt, usedAt])
}

model Order {
  id                      String      @id @default(cuid())
  publicId                String      @unique
  idempotencyKey          String      @unique
  accessTokenHash         String
  status                  OrderStatus @default(CREATED)
  gameSlug                String
  marketCode              String?
  packageId               String
  packageName             String
  amountInPaise           Int
  currency                String      @default("INR")
  presentmentCurrency     String      @default("INR")
  presentmentAmountMinor  Int?
  fxRateFromInrMicros     Int?
  fxQuotedAt              DateTime?
  billingName             String?
  billingEmail            String?
  billingPhone            String?
  billingLine1            String?
  billingLine2            String?
  billingCity             String?
  billingState            String?
  billingPostalCode       String?
  billingCountryCode      String?
  playerId                String
  zoneId                  String
  verificationMode        String
  verifiedNickname        String?
  paymentProvider         String?
  paymentSessionId        String?     @unique
  supplierProductId       String?
  supplierCategoryId      String?
  supplierOfferId         String?
  customerId              String
  customer                Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  supplierProduct         SupplierProduct? @relation(fields: [supplierProductId], references: [id], onDelete: SetNull)
  events                  OrderEvent[]
  webhooks                PaymentWebhook[]
  auditLogs               AdminAuditLog[]
  fulfilmentAttempts      FulfilmentAttempt[]
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  @@index([customerId, createdAt])
  @@index([playerId, zoneId, createdAt])
  @@index([status, createdAt])
  @@index([supplierProductId])
  @@index([gameSlug, marketCode, createdAt])
  @@index([billingCountryCode, presentmentCurrency, createdAt])
}

model OrderEvent {
  id        String   @id @default(cuid())
  type      String
  message   String
  metadata  Json?
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
}

model PaymentWebhook {
  id           String        @id @default(cuid())
  provider     String
  eventId      String?
  eventType    String
  payloadHash  String        @unique
  payload      Json
  status       WebhookStatus @default(RECEIVED)
  errorMessage String?
  orderId      String?
  order        Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  receivedAt   DateTime      @default(now())
  processedAt  DateTime?

  @@unique([provider, eventId], name: "provider_event_id")
  @@index([status, receivedAt])
  @@index([orderId, receivedAt])
}

model AdminAuditLog {
  id               String    @id @default(cuid())
  action           String
  actorFingerprint String
  actorCustomerId  String?
  actorCustomer    Customer? @relation("StaffAuditActor", fields: [actorCustomerId], references: [id], onDelete: SetNull)
  metadata         Json?
  orderId          String?
  order             Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  createdAt        DateTime  @default(now())

  @@index([actorCustomerId, createdAt])
  @@index([orderId, createdAt])
  @@index([createdAt])
}

model PricingConfiguration {
  id                   String   @id @default("default")
  usdInrRatePaise      Int      @default(9650)
  fxBufferBps          Int      @default(250)
  gatewayFeeBps        Int      @default(250)
  targetMarginBps      Int      @default(1200)
  minimumMarginInPaise Int      @default(1500)
  overheadInPaise      Int      @default(500)
  roundingInPaise      Int      @default(500)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model SupplierProduct {
  id                     String   @id @default(cuid())
  provider               String
  categoryId             String
  offerId                String
  gameSlug               String
  name                   String
  region                 String?
  supplierCurrency       String   @default("USD")
  supplierPriceUsdMicros Int
  landedCostInPaise      Int
  retailPriceInPaise     Int
  expectedMarginInPaise  Int
  expectedMarginBps      Int
  available              Boolean  @default(true)
  published              Boolean  @default(false)
  fields                 Json?
  raw                    Json?
  syncedAt               DateTime @default(now())
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  orders                 Order[]

  @@unique([provider, offerId], name: "provider_offer")
  @@index([gameSlug, published, available, retailPriceInPaise])
  @@index([provider, categoryId, available])
  @@index([syncedAt])
}

model SupplierSyncRun {
  id               String             @id @default(cuid())
  provider         String
  status           SupplierSyncStatus @default(RUNNING)
  categoriesSynced Int                @default(0)
  offersSynced     Int                @default(0)
  errorMessage     String?
  startedAt        DateTime           @default(now())
  completedAt      DateTime?

  @@index([provider, startedAt])
  @@index([status, startedAt])
}

model FulfilmentAttempt {
  id              String            @id @default(cuid())
  orderId         String
  order           Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider        String
  mode            FulfilmentMode
  status          FulfilmentStatus  @default(PLANNED)
  idempotencyKey  String            @unique
  providerOrderId String?           @unique
  requestPayload  Json?
  responsePayload Json?
  errorMessage    String?
  submittedAt     DateTime?
  completedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([orderId, createdAt])
  @@index([provider, status, createdAt])
}

model RateLimitBucket {
  id          String   @id @default(cuid())
  fingerprint String
  route       String
  windowStart DateTime
  count       Int      @default(0)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([fingerprint, route, windowStart], name: "rate_limit_bucket")
  @@index([expiresAt])
}